# Copy this file to .env and fill in your actual values.
# Never commit .env — it contains secret keys.

# Supabase — Settings → API in your Supabase project dashboard
SUPABASE_URL=
SUPABASE_ANON_KEY=

# PayMongo — Developers → API Keys in your PayMongo dashboard
# Secret key is server-side only (never paste it into frontend HTML files)
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
