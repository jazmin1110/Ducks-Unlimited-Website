# Copy this file to .env and fill in your actual values.
# Never commit .env — it contains secret keys.
#
# For Vercel deployments, set these in the Vercel dashboard under
# Settings → Environment Variables (not in this file).


# ─── Supabase (Settings → API in your Supabase project dashboard) ────────────

# Used by both frontend and backend
SUPABASE_URL=
# Public — safe to expose in frontend code. RLS controls access.
SUPABASE_ANON_KEY=

# SERVER-SIDE ONLY — bypasses RLS. Used by serverless functions in /api/*
# to update orders and decrement inventory after a payment is confirmed.
# Never expose this in frontend code.
SUPABASE_SERVICE_ROLE_KEY=


# ─── PayMongo (Developers → API Keys in your PayMongo dashboard) ─────────────

# Server-side only — used to create payment links via the PayMongo API
PAYMONGO_SECRET_KEY=

# Public key — fine for frontend code (not used yet but reserved for future flows)
PAYMONGO_PUBLIC_KEY=

# Webhook signing secret — set when you register a webhook in the PayMongo
# dashboard at Developers → Webhooks. Used to verify webhook authenticity.
PAYMONGO_WEBHOOK_SECRET=


# ─── Public site URL ─────────────────────────────────────────────────────────

# Used by /api/create-payment to build the redirect URL PayMongo sends
# the customer back to after payment.
# Local dev:   http://localhost:3000
# Production:  https://ducks-unlimited-website.vercel.app
SITE_URL=
